{
  "name": "ado-assist",
  "version": "0.1.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awaybreaktoday/ADOassist.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "ado-assist": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.5"
  }
}
